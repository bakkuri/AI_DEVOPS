# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Optional: OpenAI Model (defaults to gpt-4o in the code)
# OPENAI_MODEL=gpt-4o

# Optional: Cost analysis settings
# ANALYSIS_TEMPERATURE=0.7
# ANALYSIS_MAX_TOKENS=2000

# Database Configuration (Amazon RDS for PostgreSQL)
# Provide a full DATABASE_URL for production, or enable one of the
# alternate authentication methods below (RDS IAM or local test DB).
# Format: postgresql://username:password@host:port/database
# Example: postgresql://admin:password123@my-rds.us-east-1.rds.amazonaws.com:5432/cost_detective
DATABASE_URL=postgresql://username:password@localhost:5432/cost_detective

# Optional: Enable AWS RDS IAM authentication (no static DB password stored)
# When true the app will generate an IAM auth token via boto3 and connect with TLS.
# Set USE_RDS_IAM=true and ensure AWS credentials are available (instance role or env).
USE_RDS_IAM=false
AWS_REGION=us-east-1
# Optional manual components (used when DATABASE_URL does not include them)
DB_USER=postgres
DB_HOST=database-1-instance-1.culyy0o0qw3n.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres

# Test mode: use a lightweight local SQLite DB for running quick tests
# Set USE_TEST_DB=true to run the backend against a local SQLite file
# (no external Postgres required). Configure path with TEST_SQLITE_DB_PATH.
USE_TEST_DB=false
TEST_SQLITE_DB_PATH=:memory:

# AWS Secrets Manager (optional): set USE_AWS_SECRETS=true and specify
# SECRET_NAME to fetch DB credentials from Secrets Manager. The secret
# should contain JSON like {"username":"...","password":"...","host":"...","port":5432,"dbname":"..."}
USE_AWS_SECRETS=false
SECRET_NAME=

# JWT Configuration
# Generate a secret key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
