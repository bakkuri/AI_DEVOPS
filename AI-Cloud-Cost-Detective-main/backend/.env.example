# OpenAI API key used for AI-powered cost analysis.
OPENAI_API_KEY=

# AWS Credentials Configuration
# AWS CLI must be installed and credentials must be configured.
# Choose ONE of the following methods:
#
# Method 1: AWS CLI configuration (recommended)
#   Run: aws configure
#   This will prompt for Access Key ID, Secret Access Key, region, and output format
#
# Method 2: Environment variables
#   AWS_ACCESS_KEY_ID=your-access-key-id
#   AWS_SECRET_ACCESS_KEY=your-secret-access-key
#
# Method 3: AWS credentials file (~/.aws/credentials)
#   Automatically loaded if present
#
# Required AWS IAM permissions:
#   - resource-groups:ListGroups
#   - resource-groups:ListGroupResources
#   - ec2:Describe* (for instance details)
#   - rds:Describe* (for RDS details)
#   - s3:List* (for bucket details)
#   - iam:List* (for IAM details)
#   - And other read-only describe permissions for AWS services to analyze

#   postgresql://<your-user>@localhost:5432/ai_cost_detective
DATABASE_URL=postgresql://<your-user>@localhost:5432/ai_cost_detective

# Optional: Enable AWS RDS IAM authentication when connecting to Amazon RDS
# with no static DB password. Requires AWS credentials and a full DATABASE_URL.
USE_RDS_IAM=false
AWS_REGION=us-east-1

# Optional manual DB components used by RDS IAM path if DATABASE_URL is incomplete.
DB_USER=<your-user>
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_cost_detective

# Local test database mode.
# Set USE_TEST_DB=true to use SQLite instead of PostgreSQL.
USE_TEST_DB=false
TEST_SQLITE_DB_PATH=:memory:

# JWT configuration
# Generate a secret key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
